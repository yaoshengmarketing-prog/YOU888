---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE } from '../consts';

const banners = [
  ['01','體育投注 每天投注彩金高達2,888'],['02','體育救援金 高達15,888'],['03','體育連贏彩金 高達8,888'],
  ['04','真人娛樂 連贏再送高達888,888'],['05','真人娛樂 每天投注彩金高達6,888'],['06','真人娛樂 每天返水救援金3%'],
  ['07','電子捕魚棋牌 贏再送2%'],['08','電子捕魚棋牌 救援金5%'],['09','電子捕魚棋牌 每日投注彩金高達2,888'],
  ['10','新會員註冊 贈送免費彩金88'],['11','每天簽到 每天領取獎勵'],['12','極速ATM存款 每筆贈0.5%'],
  ['13','預約取款 額外加送1%'],['14','首存第30天 贈送高達18,888'],['15','首存第7天 贈送高達15,888'],
  ['16','EXpay 操作指南'],['17','虛擬幣存取款 尊享三重豪禮'],['18','EXpay錢包 送88體驗金'],
  ['19','神秘彩金 每日領獎'],['20','自己當代理賺錢 每週賺500,000'],
];

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const fmt = (d) => d.toISOString().slice(0, 10);
const canonical = SITE.url + '/';
---
<!DOCTYPE html>
<html lang="zh-Hant-TW">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>YOU888 娛樂城｜體育投注・真人・電子捕魚棋牌・每日優惠</title>
<meta name="description" content="YOU888 娛樂城提供體育投注、真人、電子捕魚棋牌等多元遊戲，新會員註冊送 88 體驗金，每日簽到領獎、首存加碼、EXpay 與虛擬幣快速存取款，24 小時客服全年不打烊。">
<link rel="canonical" href={canonical}>
<link rel="alternate" type="application/rss+xml" title={SITE.blogTitle} href="/rss.xml">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800;900&display=swap" rel="stylesheet">
<style is:global>
  *{box-sizing:border-box}
  body{margin:0;background:#f4f1ea;font-family:"PingFang TC","Microsoft JhengHei","Noto Sans TC",system-ui,sans-serif;-webkit-font-smoothing:antialiased;color:#3a3020}
  a{color:#9a6f2d;text-decoration:none}a:hover{color:#8a6420}
  .cinzel{font-family:Cinzel,serif}
  @keyframes you-mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  .hero-wrap{position:relative;width:100%;aspect-ratio:1920/700;border-radius:20px;overflow:hidden;box-shadow:0 18px 50px rgba(150,110,50,.22);border:1px solid rgba(200,160,80,.3);background:#f4ead2}
  .slide{position:absolute;inset:0;opacity:0;transition:opacity .6s;z-index:1}
  .slide.active{opacity:1;z-index:2}
  .slide img{width:100%;height:100%;object-fit:cover;display:block}
  .hero-count{position:absolute;top:14px;left:16px;z-index:15;padding:5px 13px;border-radius:99px;background:rgba(58,48,32,.55);color:#f3e0af;font-family:Cinzel,serif;font-weight:700;font-size:13px;letter-spacing:1px}
  .hero-btn{position:absolute;top:50%;transform:translateY(-50%);z-index:20;width:44px;height:44px;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,.85);color:#8a6420;font-size:20px;box-shadow:0 3px 12px rgba(0,0,0,.15)}
  .hero-btn:hover{background:#fff}.hero-prev{left:16px}.hero-next{right:16px}
  .hero-dots{position:absolute;left:16px;right:16px;bottom:16px;display:flex;justify-content:center;flex-wrap:wrap;gap:8px;z-index:20}
  .hero-dots button{height:8px;width:8px;border-radius:99px;border:none;cursor:pointer;padding:0;background:rgba(120,90,40,.35);box-shadow:0 1px 4px rgba(0,0,0,.25);transition:all .3s}
  .hero-dots button.active{width:26px;background:#b7873c}
  .cat-tile{display:flex;flex-direction:column;align-items:center;gap:14px;padding:32px 18px;border-radius:18px;background:linear-gradient(180deg,#fff,#fbf4e6);border:1px solid rgba(200,160,80,.28);box-shadow:0 6px 20px rgba(150,110,50,.1);transition:all .2s}
  .cat-tile:hover{transform:translateY(-5px);box-shadow:0 14px 32px rgba(150,110,50,.22);border-color:rgba(200,160,80,.6)}
  .cta-btn{display:inline-block;padding:16px 46px;border-radius:12px;font-size:18px;font-weight:800;letter-spacing:1px;color:#8a5a10;background:#fff;box-shadow:0 10px 26px rgba(120,80,20,.3);transition:all .18s}
  .cta-btn:hover{transform:translateY(-2px);box-shadow:0 14px 32px rgba(120,80,20,.38);color:#8a5a10}
  .p-card{display:flex;flex-direction:column;border-radius:18px;overflow:hidden;background:#fff;border:1px solid rgba(200,160,80,.28);box-shadow:0 6px 20px rgba(150,110,50,.1);transition:all .2s}
  .p-card:hover{transform:translateY(-5px);box-shadow:0 16px 34px rgba(150,110,50,.2);border-color:rgba(200,160,80,.55)}
  .p-card .th{aspect-ratio:16/9;overflow:hidden}.p-card .th img{width:100%;height:100%;object-fit:cover;display:block}
  .chip{align-self:flex-start;font-size:12px;font-weight:700;color:#7a5410;background:linear-gradient(135deg,#f3e0af,#cf9f4d);padding:4px 12px;border-radius:99px}
  @media (max-width:900px){.cat-grid{grid-template-columns:repeat(2,1fr)!important}.service-grid{grid-template-columns:repeat(2,1fr)!important}.news-grid{grid-template-columns:1fr!important}h2{font-size:30px!important}}
</style>
</head>
<body>
<div style="min-height:100vh">

  <SiteHeader />

  <section style="background:linear-gradient(180deg,#fbf5e8,#f4ead2)" aria-label="主視覺輪播">
