        <div class="hero-dots" id="heroDots" role="tablist" aria-label="輪播選擇"></div>
      </div>
    </div>
  </section>

  <section style="background:#fff; border-top:1px solid rgba(200,160,80,.2); border-bottom:1px solid rgba(200,160,80,.2)" aria-label="最新公告">
    <div style="max-width:1440px; margin:0 auto; padding:0 32px; display:flex; align-items:center; gap:16px; height:58px">
      <div style="flex:none; display:flex; align-items:center; gap:8px; padding:7px 16px; border-radius:99px; background:linear-gradient(135deg,#e8c583,#b7873c); color:#fff; font-weight:700; font-size:14px; box-shadow:0 3px 10px rgba(183,135,60,.35)"><span style="width:6px;height:6px;border-radius:50%;background:#fff;display:block"></span> 最新公告</div>
      <div style="position:relative; flex:1; overflow:hidden; -webkit-mask-image:linear-gradient(90deg,transparent,#000 4%,#000 96%,transparent); mask-image:linear-gradient(90deg,transparent,#000 4%,#000 96%,transparent)">
        <div style="display:inline-flex; white-space:nowrap; animation:you-mq 32s linear infinite">
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>新會員註冊即送 88 體驗金，簽到再領每日獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>首存最高加碼 18,888，存越多送越多</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>EXpay 與虛擬幣極速存取款，每筆再享回饋</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>新會員註冊即送 88 體驗金，簽到再領每日獎勵</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>首存最高加碼 18,888，存越多送越多</span>
          <span style="display:inline-flex; align-items:center; gap:9px; padding:0 30px; font-size:15px; color:#4a4033; font-weight:500"><i style="width:5px;height:5px;border-radius:50%;background:#c9a24a;display:inline-block"></i>EXpay 與虛擬幣極速存取款，每筆再享回饋</span>
        </div>
      </div>
      <a href="/blog/categories/promotions/" style="flex:none; font-size:14px; font-weight:600; color:#9a6f2d; padding:6px 12px; border-radius:8px">更多 ›</a>
    </div>
  </section>

  <section id="games" style="max-width:1440px; margin:0 auto; padding:72px 32px 12px; text-align:center">
    <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#c0a05a">TOP GAMES</p>
    <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px">熱門遊戲分類</h2>
    <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
      <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#c9a24a)"></span><span style="color:#8a6420">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#c9a24a,transparent)"></span>
    </div>
    <div class="cat-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px">
      {[['體','體育投注','SPORTS'],['真','真人視訊','LIVE'],['電','電子遊戲','SLOTS'],['魚','捕魚遊戲','FISHING'],['棋','棋牌遊戲','POKER'],['彩','彩票遊戲','LOTTERY'],['競','電競投注','ESPORTS'],['全','全部遊戲','ALL GAMES']].map(([g,zh,en]) => (
        <a href="#" class="cat-tile">
          <span style="width:78px; height:78px; border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:34px; font-weight:900; color:#7a5410; background:linear-gradient(135deg,#f3e0af,#cf9f4d); box-shadow:0 6px 16px rgba(183,135,60,.35),inset 0 1px 2px rgba(255,255,255,.6)">{g}</span>
          <span style="font-size:18px; font-weight:700; color:#3a3020">{zh}</span>
