<script is:inline>
(function(){
  var slides = Array.prototype.slice.call(document.querySelectorAll('#hero .slide'));
  var dotsWrap = document.getElementById('heroDots');
  var curEl = document.getElementById('heroCur');
  var idx = 0, timer = null, N = slides.length;
  function pad(n){ return String(n+1).padStart(2,'0'); }
  slides.forEach(function(_,i){
    var b = document.createElement('button');
    b.setAttribute('role','tab'); b.setAttribute('aria-label','第 '+(i+1)+' 張');
    b.addEventListener('click', function(){ go(i); reset(); });
    dotsWrap.appendChild(b);
  });
  var dots = Array.prototype.slice.call(dotsWrap.children);
  function go(i){ idx=(i+N)%N; slides.forEach(function(s,j){ s.classList.toggle('active',j===idx); }); dots.forEach(function(d,j){ d.classList.toggle('active',j===idx); }); curEl.textContent=pad(idx); }
  function next(){ go(idx+1); }
  function reset(){ clearInterval(timer); timer=setInterval(next,5000); }
  document.getElementById('heroNext').addEventListener('click', function(){ next(); reset(); });
  document.getElementById('heroPrev').addEventListener('click', function(){ go(idx-1); reset(); });
  go(0); reset();
})();
</script>
</body>
</html>
