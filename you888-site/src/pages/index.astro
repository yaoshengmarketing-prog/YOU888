        </a>
      ))}
    </div>
  </section>

  <!-- ===== 最新文章（部落格自動帶入）===== -->
  <section style="max-width:1440px; margin:0 auto; padding:72px 32px 8px; text-align:center">
    <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#c0a05a">LATEST POSTS</p>
    <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px">最新文章</h2>
    <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
      <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#c9a24a)"></span><span style="color:#8a6420">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#c9a24a,transparent)"></span>
    </div>
    <div class="news-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:26px; text-align:left">
      {posts.map((p) => (
        <a href={`/post/${p.slug}/`} class="p-card">
          <div class="th">{p.data.cover && <img src={p.data.cover} alt={p.data.coverAlt ?? p.data.title} loading="lazy" />}</div>
          <div style="padding:20px 22px 24px; display:flex; flex-direction:column; gap:10px">
            <span class="chip">{CATEGORIES[p.data.category]}</span>
            <h3 style="font-size:19px; font-weight:800; margin:2px 0; color:#3a3020; line-height:1.4">{p.data.title}</h3>
            <p style="font-size:14px; color:#6b6252; margin:0">{p.data.description}</p>
            <div style="font-size:13px; color:#a08a5e; margin-top:4px">{fmt(p.data.pubDate)} · {p.data.author}</div>
          </div>
        </a>
      ))}
    </div>
    <div style="margin-top:30px">
      <a href="/blog/" style="display:inline-block; font-size:15px; font-weight:600; color:#9a6f2d; padding:8px 4px; border-bottom:1px solid rgba(154,111,45,.4)">查看全部文章 →</a>
    </div>
  </section>

  <section id="service" style="margin-top:64px; background:linear-gradient(180deg,#eef2f6,#e4ebf2); padding:64px 32px">
    <div style="max-width:1440px; margin:0 auto; text-align:center">
      <p class="cinzel" style="font-size:15px; letter-spacing:3px; margin:0 0 6px; color:#8397ab">QUALITY SERVICE</p>
      <h2 style="font-size:42px; font-weight:900; margin:0 0 10px; letter-spacing:2px; color:#2c3644">優質服務</h2>
      <div style="display:flex; align-items:center; justify-content:center; gap:14px; margin-bottom:44px">
        <span style="width:60px; height:2px; background:linear-gradient(90deg,transparent,#b7873c)"></span><span style="color:#b7873c">◆</span><span style="width:60px; height:2px; background:linear-gradient(90deg,#b7873c,transparent)"></span>
      </div>
      <div class="service-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:30px">
        {[['極速','快速出款免等待','FAST PAYOUT'],['加密','資金安全有保障','SECURE'],['全裝置','支援所有裝置','ALL DEVICES'],['24H','全年客服不打烊','SUPPORT']].map(([big,zh,en]) => (
          <div style="display:flex; flex-direction:column; align-items:center; gap:16px">
            <span class="cinzel" style="width:128px; height:128px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:radial-gradient(circle at 50% 40%,#2e3646,#1c2230); border:5px solid #cf9f4d; box-shadow:0 10px 26px rgba(40,50,70,.3),inset 0 0 20px rgba(0,0,0,.4); font-size:28px; font-weight:900; color:#f3e0af">{big}</span>
            <div><p style="font-size:18px; font-weight:700; color:#2c3644; margin:0 0 3px">{zh}</p><p class="cinzel" style="font-size:12px; letter-spacing:1.5px; color:#9fb0c2; margin:0">{en}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="cta" style="position:relative; overflow:hidden; background:linear-gradient(135deg,#e8c583,#b7873c)">
    <div style="position:absolute; inset:0; background-image:radial-gradient(rgba(255,255,255,.16) 1px,transparent 1px); background-size:22px 22px; opacity:.6"></div>
    <div style="position:relative; max-width:900px; margin:0 auto; padding:72px 32px; text-align:center; color:#fff">
      <p class="cinzel" style="letter-spacing:3px; font-size:14px; margin:0 0 12px; color:rgba(255,255,255,.85)">JOIN YOU888</p>
      <h2 style="font-size:40px; font-weight:900; margin:0 0 14px; letter-spacing:1px; text-shadow:0 2px 8px rgba(120,80,20,.25)">立即加入，開啟你的遊戲之旅</h2>
      <p style="font-size:17px; line-height:1.7; margin:0 auto 32px; max-width:520px; color:rgba(255,255,255,.92)">30 秒完成註冊，新會員登入即享 88 體驗金與每日簽到獎勵。</p>
      <a href="#" class="cta-btn">免費註冊 ›</a>
    </div>
  </section>

  <footer style="background:#23282f; color:#9aa0aa; padding:44px 32px; text-align:center; font-size:13px; line-height:1.9">
    <div class="cinzel" style="font-weight:800; font-size:20px; letter-spacing:2px; color:#e8c583; margin-bottom:10px">YOU888</div>
    <p style="margin:0"><a href="/blog/categories/platform-guide/" style="color:#c9b48a">平台指南</a> · <a href="/blog/categories/promotions/" style="color:#c9b48a">優惠活動</a> · <a href="/blog/categories/deposit-withdraw/" style="color:#c9b48a">存款與出金</a> · <a href="/blog/categories/security/" style="color:#c9b48a">安全查核</a> · <a href="/blog/" style="color:#c9b48a">部落格</a></p>
