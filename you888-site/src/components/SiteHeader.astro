---
// 共用頁首。home 傳 true 時錨點連回首頁區塊
const { home = false } = Astro.props;
const base = home ? '' : '/';
---
<header class="site-header">
  <div class="container" style="height:76px; display:flex; align-items:center; gap:28px">
    <a href="/" style="display:flex; align-items:center; gap:11px; flex:none; color:inherit">
      <span style="width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#e8c583,#b7873c); display:flex; align-items:center; justify-content:center; box-shadow:0 3px 10px rgba(180,140,70,.35)">
        <i style="width:15px; height:15px; border:2.5px solid #fff; border-radius:4px; transform:rotate(45deg); display:block"></i>
      </span>
      <span class="brand-txt">YOU888</span>
    </a>
    <nav class="nav-desktop" style="display:flex; align-items:center; gap:2px; flex:1; flex-wrap:nowrap; overflow-x:auto" aria-label="主選單">
      <a href="/blog/categories/platform-guide/" class="nav-link">平台指南</a>
      <a href="/blog/categories/promotions/" class="nav-link">優惠活動</a>
      <a href="/blog/categories/game-guide/" class="nav-link">遊戲玩法</a>
      <a href="/blog/categories/deposit-withdraw/" class="nav-link">存款與出金</a>
      <a href="/blog/categories/security/" class="nav-link">安全查核</a>
      <a href="/blog/" class="nav-link" style="font-weight:700; color:#8a6420">部落格</a>
    </nav>
    <div style="display:flex; align-items:center; gap:8px; flex:none; margin-left:auto">
      <a href="/" class="btn-reg">回首頁</a>
    </div>
  </div>
</header>
