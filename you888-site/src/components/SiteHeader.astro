---
// 全站統一頁首：LOGO(回首頁) + 8 分類 + 登入/註冊；手機收進漢堡選單
import { CATEGORY_ORDER, CATEGORIES, SITE } from '../consts';
---
<header class="site-header">
  <div class="container hdr">
    <button class="hamburger" id="navToggle" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <a href="/" class="brand" aria-label="回首頁">
      <span class="brand-mark"><i></i></span>
      <span class="brand-txt">YOU888</span>
    </a>

    <nav class="main-nav" id="mainNav" aria-label="主選單">
      {CATEGORY_ORDER.map((slug) => (
        <a href={`/${slug}/`} class="nav-link">{CATEGORIES[slug]}</a>
      ))}
    </nav>

    <div class="hdr-cta">
      <a href={SITE.loginUrl} class="btn-login">登入</a>
      <a href={SITE.registerUrl} class="btn-reg">註冊</a>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('navToggle');
    var nav = document.getElementById('mainNav');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      var open = nav.classList.toggle('open');
      btn.classList.toggle('is-open', open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // 點選單連結後自動收合
    nav.addEventListener('click', function (e) {
      if (e.target && e.target.tagName === 'A') {
        nav.classList.remove('open');
        btn.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
